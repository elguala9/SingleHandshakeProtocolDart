# SHSP NAT Testing Configuration

# Docker settings
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest
DOCKER_NETWORK_NAME=shsp_test_network
DOCKER_NETWORK_SUBNET=192.168.10.0/24

# Peer 1 Configuration
PEER1_ID=peer1
PEER1_IP=192.168.10.10
PEER1_PORT=5000
PEER1_CONTAINER_NAME=shsp_peer1

# Peer 2 Configuration
PEER2_ID=peer2
PEER2_IP=192.168.10.20
PEER2_PORT=5001
PEER2_CONTAINER_NAME=shsp_peer2

# NAT Types to test (space-separated)
NAT_TYPES="full_cone address_restricted port_restricted symmetric"

# Test timeouts (in seconds)
HANDSHAKE_TIMEOUT=10
WAIT_TIME_BETWEEN_TESTS=2
CONTAINER_STARTUP_WAIT=5

# Results configuration
RESULTS_DIR=./results
RESULTS_FORMAT=json
GENERATE_HTML_REPORT=true

# Logging
LOG_LEVEL=INFO
VERBOSE_OUTPUT=false
KEEP_LOGS=true

# Performance tuning
MAX_CONCURRENT_TESTS=1
RETRY_ON_FAILURE=false
CLEANUP_AFTER_TEST=true

# Advanced options
USE_HOST_NETWORK=false
ENABLE_NAT_DEBUG=false
COLLECT_METRICS=true
SAVE_PACKET_DUMPS=false

# Dart test script path
TEST_SCRIPT_PATH=./scripts/handshake_test.dart

# Python aggregation script path
AGGREGATION_SCRIPT_PATH=./scripts/aggregate_results.py

# Network simulation (packet loss, latency) - currently unused
SIMULATE_PACKET_LOSS=0
SIMULATE_LATENCY_MS=0
